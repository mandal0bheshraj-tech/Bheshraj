rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Auth verification and ownership checks
    function isUserOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUserProfile(data) {
      return data.uid == request.auth.uid &&
             data.uid is string && data.uid.size() <= 128 &&
             (!('email' in data) || (data.email is string && data.email.size() <= 256)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 32)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 2048)) &&
             data.createdAt == request.time;
    }

    // Farm Project Validation
    function isValidFarmProject(data) {
      return data.projectId is string && data.projectId.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 128 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
             data.state is map &&
             data.createdAt is timestamp &&
             data.updatedAt == request.time;
    }

    // Core Rules mapping
    match /users/{userId} {
      allow get: if isUserOwner(userId);
      allow create: if isUserOwner(userId) && isValidUserProfile(incoming());
      allow update: if isUserOwner(userId) && isValidUserProfile(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isUserOwner(userId);

      match /projects/{projectId} {
        allow get, list: if isUserOwner(userId);
        allow create: if isUserOwner(userId) && isValidId(projectId) && isValidFarmProject(incoming()) && incoming().createdAt == request.time;
        allow update: if isUserOwner(userId) && isValidId(projectId) && isValidFarmProject(incoming()) && incoming().createdAt == existing().createdAt;
        allow delete: if isUserOwner(userId) && isValidId(projectId);
      }
    }
  }
}
